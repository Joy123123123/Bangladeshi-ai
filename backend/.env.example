# ============================================================
# Bangladeshi-ai — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── AI API Keys ──────────────────────────────────────────────
# Google Gemini  → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek       → https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Grok (xAI)     → https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bangladeshi_ai

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_ALGORITHM=HS256
# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ──────────────────────────────────────────────
APP_NAME=Bangladeshi-ai
APP_ENV=development          # development | production
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Default AI Model ─────────────────────────────────────────
# Options: gemini | deepseek | grok
DEFAULT_AI_MODEL=gemini

# ── Rate Limiting ────────────────────────────────────────────
# Requests per minute per IP (unauthenticated users)
RATE_LIMIT_ANONYMOUS=20
# Requests per minute per user (authenticated)
RATE_LIMIT_AUTHENTICATED=60
